# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=gns_user
DB_PASSWORD=gns_password
DB_NAME=gns_db
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=5

# Server Configuration
APP_PORT=8080
RATELIMIT_BURST=10
RATELIMIT_REQUEST_PER_SECOND=1000

JWT_SECRET=supersecretkey
JWT_REFRESH_SECRET=anothersecretkey
JWT_ACCESS_TOKEN_EXPIRATION=86400
JWT_REFRESH_TOKEN_EXPIRATION=86400
ENFORCER_DURATION_SECONDS=3600

CACHE_HOST=redis
CACHE_PORT=6379
CACHE_DB=0

# WebSocket Configuration
WEBSOCKET_READ_BUFFER_SIZE=1024
WEBSOCKET_WRITE_BUFFER_SIZE=1024

# Redis Configuration (if using Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Logging
LOG_LEVEL=info